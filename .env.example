# ════════════════════════════════════════════════════════
#  StudyFlow — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha com seus valores
#  NUNCA commite o .env com valores reais
# ════════════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_PASSWORD=sua_senha_forte_aqui

# ── n8n ─────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=sua_senha_forte_aqui

# URL pública do n8n (via Cloudflare Tunnel)
WEBHOOK_URL=https://seu-dominio.com

# ── Telegram ────────────────────────────────────────────
# Gerado via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq ────────────────────────────────────────────────
# Gerado em console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Trello ──────────────────────────────────────────────
# Gerado em https://trello.com/app-key
TRELLO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TRELLO_TOKEN=ATTAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GitHub ──────────────────────────────────────────────
# Token com escopo repo (para scripts de provisionamento)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── n8n API Key ─────────────────────────────────────────
# Gerado em n8n → Settings → API
N8N_API_KEY=eyJhbGci...
